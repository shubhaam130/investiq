# InvestIQ — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ─────────────────────────────────────────────
# Anthropic API Key  (enables live AI analysis)
# Get yours at: https://console.anthropic.com → API Keys
# Without this key the app runs in Demo Mode with pre-written responses.
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port (Railway / Render / Fly.io set this automatically)
PORT=3000

# CORS origin — set to your live domain in production, or * for development
ALLOWED_ORIGIN=*
